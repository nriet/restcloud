# Git
.git/
.gitattributes
.gitignore

# Docker
.dockerignore
Dockerfile*
docker-compose*.yml

# IDE & OS
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# Build artifacts
*.tar.gz
*.zip
*.war
*.jar

# Temp files
tmp/
temp/

# README & docs (not needed in build context)
README.md

